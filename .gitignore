# Secrets — NEVER commit
.env
*.env
!.env.example

# Runtime data: SQLite DBs, client media, zips, tmp, brand uploads (+ owned by mise user)
data/

# Local backup snapshots (may contain DB dumps / client PII — never commit)
_bak/
_backups/
backups/

# Python
.venv/
venv/
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/

# uv may create a lockfile locally; CI and prod install from requirements.txt
uv.lock

# Editor / OS cruft
*.bak
*.bak.*
*.bak-*
*.swp
.DS_Store
.r/

# Fable 5 design export — local reference only, never commit
_design/
