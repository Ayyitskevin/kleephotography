# Copy to /opt/mise/.env, chmod 600, owner mise.
# Generate the secret:  python3 -c "import secrets; print(secrets.token_urlsafe(32))"
MISE_SECRET_KEY=CHANGE_ME
MISE_ADMIN_PASSWORD=CHANGE_ME
MISE_BASE_URL=http://flow:8400
MISE_SITE_NAME=Kevin Lee Photography
# Set true once serving via HTTPS through the tunnel:
MISE_COOKIE_SECURE=false
# Public marketing (optional)
# MISE_INSTAGRAM_URL=https://www.instagram.com/your-handle/
MISE_PLAUSIBLE_DOMAIN=kleephotography.com
# Sample gallery for prospects — slug auto-detected if unset (title/slug contains "sample")
# MISE_DEMO_GALLERY_SLUG=sample-tasting-menu
# MISE_DEMO_GALLERY_PIN=1234

# ── Integrations (all optional; each feature stays dormant until its keys are set) ──
# Stripe Checkout + webhook (invoice pay page). Webhook secret from the CLI/dashboard.
# MISE_STRIPE_SECRET_KEY=sk_live_xxx
# MISE_STRIPE_WEBHOOK_SECRET=whsec_xxx
# Gmail SMTP for manual document sends (use a Google app password, not your login).
# MISE_GMAIL_USER=you@gmail.com
# MISE_GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
# Notion one-way status sync (invoice sent/paid → Session page).
# MISE_NOTION_TOKEN=ntn_xxx
# MISE_NOTION_SESSIONS_DB=
# MISE_NOTION_BOOKINGS_DB=
# Google Calendar OAuth (scheduling availability). Calendar id defaults to "primary".
# MISE_GOOGLE_CLIENT_ID=
# MISE_GOOGLE_CLIENT_SECRET=
# MISE_GOOGLE_CALENDAR_ID=primary
# Odysseus caption AI hand-off (admin "draft caption" button).
# MISE_ODYSSEUS_CAPTION_URL=
# MISE_ODYSSEUS_CAPTION_TOKEN=
# Bearer token that arms the read-only shot-list API for Odysseus preshoot packs.
# MISE_SHOTS_TOKEN=
# Argus vision analyze on gallery publish (one-way POST + inbound gallery index).
# MISE_ARGUS_URL=http://mickey:8010
# MISE_ARGUS_TOKEN=
# MISE_ARGUS_TIMEOUT=30
# MISE_ARGUS_ANALYZE_LIMIT=0

# Plutus print upsell (Phase 1) — queued after Argus callback or on publish when Argus off
# MISE_PLUTUS_URL=http://strix-halo-a9-mega:8030
# MISE_PLUTUS_TOKEN=
# MISE_PLUTUS_TIMEOUT=30
# Revenue goal bar on the admin home (whole dollars; 0/unset hides it).
# MISE_MONTHLY_GOAL=0
